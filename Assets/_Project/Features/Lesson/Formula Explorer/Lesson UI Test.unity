--- !u!114 &2093510390
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2093510387}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0af0377aac8b31c4c976e3c1bba42283, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: Center of Mass (Two Objects)
  formula: COM = (m<sub>1</sub> x<sub>1</sub> + m<sub>2</sub> x<sub>2</sub>) / (m<sub>1</sub>
    + m<sub>2</sub>)
  breakdown: 'm<sub>1</sub> = mass of object 1

    x<sub>1</sub> = position of object
    1

    m<sub>2</sub> = position of object 2

    x<sub>2</sub> = mass of object
    2'
  solution: '= (ma * xa + mb * xb) / (ma + mb)

    = (mxa + mxb) / mab

    = mxab
    / mab

    COM = answer m'
  computations:
  - alias: mxa
    expression: ma * xa
  - alias: mxb
    expression: mb * xb
  - alias: mab
    expression: ma + mb
  - alias: mxab
    expression: ma * xa + mb * xb
  - alias: answer
    expression: (ma * xa + mb * xb) / (ma + mb)
  variableSliders:
  - {fileID: 788047480}
  - {fileID: 38242686}
  - {fileID: 535176340}
  - {fileID: 789586757}
  titleText: {fileID: 25321479}
  formulaText: {fileID: 1896614336}
  breakdownText: {fileID: 1814805433}
  formulaText2: {fileID: 167794966}
  solutionText: {fileID: 407782091}
  answerText: {fileID: 1306735680}
