  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: Acoustics is the branch of science dealing with the study, analysis, and
    application of sound, which is a disturbance of molecules within a given substance.
    This disturbance must be caused by a wave, however. In this context, a wave is
    not just a graphical representation of harmonic motion; rather, it is a medium
    that drives a substance to disturb its molecules by use of harmonic motion. This
    harmonic motion is called vibration.
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
