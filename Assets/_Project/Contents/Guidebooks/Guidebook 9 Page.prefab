  m_text: 'Power is the computed amount of work done within a certain time. Its derived
    unit is the Watt (WW), named after the mechanical engineer James Watt. Formula:
    P = W/t where W = work and t = time.

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
