  m_text: "Volume\r\n1 L = 10\u20133 m3\r\n1 L = 1 dm3\r\n1 L = 103 cm3\r\n1 L =
    1.0567 qt\r\n1 gal = 4 qt\r\n1 gal = 3.7854 L\r\n1 cm3 = 1 mL\r\n1 in3 = 16.4
    cm3\r\n"
