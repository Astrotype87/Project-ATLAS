      m_Calls: []
  m_text: "This is also similar with the rectilinear acceleration, only this time,
    it involves angular velocity. It shows the changes in an object\u2019s angular
    velocity per unit of time. \nFormula: \u03B1 = \u03C9 / t where \u03C9 = angular
    velocity and t = time."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
