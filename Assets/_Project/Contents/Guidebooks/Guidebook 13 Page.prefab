  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "It is the measurement where the angle through which a point, line, or
    body has rotated in a specified direction, about a specified axis. It may also
    refer to the difference between the initial (0) and final (f) angular positions.
    It is also similar to the linear displacement. Formula: \u0394\u03B8 = \u0394x
    / r where \u0394x = displacement and r = radius"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
