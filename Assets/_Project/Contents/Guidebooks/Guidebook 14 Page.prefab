  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "To perform angular work (W_r), which is work done by a rotating system.
    Angular work, however, translates work within a certain angular displacement
    in which it is known as the arc length. Formula: W_\u03C4 = \u03C4 \u0394\u03B8
    where \u03C4 = torque and \u0394\u03B8 = angular displacement."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
