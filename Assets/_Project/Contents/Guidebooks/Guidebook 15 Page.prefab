      m_Calls: []
  m_text: "This speed required by any object to escape or break free from gravitational
    influence.\nFormula: v_e = \u221A2Gm/r where G = 6.673 \xD7 10^\u207B\xB9\xB9
    \xD7 m\xB3/kg \u2022 s\xB2 (gravitation constant), m = mass and r = radius/distance
    from the center of gravity."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
