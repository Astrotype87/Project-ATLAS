  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'The Law of Conservation of Momentum, wherein momentum is a constant in
    all things that have mass. It also defines that the vector sum of all given momenta
    (sing. momentum) of all objects within a system, that sum cannot be changed by
    any other interactions within that system. Simply put, if one object has a momentum
    within a certain direction, the other objects must have the same momentum, but
    traveling in directions opposite that of the other.

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
