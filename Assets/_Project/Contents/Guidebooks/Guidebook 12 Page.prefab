--- !u!114 &6813027140109710251
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6553871907374799547}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "There is another kind of collision, in which if the target does not bend
    to the force generated by the incoming projectile, the said target will move
    alongside the already-moving object, or the two interacting objects will stick
    together, if enough force and momentum is generated. This collision is evident
    in vehicular accidents, target ranges, or even in simple pastimes like playing
    football in all its variants (American, soccer, and rugby), and, as young kids,
    throwing clay at the wall. This kind of collision is called inelastic collision.
    Inelastic collision occurs more often than elastic collision because, in reality,
    energy is lost more than be conserved. Inelastic collision also has a coefficient
    in it, called the coefficient of restitution, or COR. This coefficient shows
    the ratio between objects before and after impact, \n\nCoefficient of Restitution:
    COR = v_f / v_0 where v_f = velocity after impact and is v_0 = velocity before
    impact\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
