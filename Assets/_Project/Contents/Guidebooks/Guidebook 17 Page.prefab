  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A simple pendulum is a system consists of a particle of mass m (called
    the bob of the pendulum) suspended from one end of a massless string of fixed
    length L that is attached at the other end. The bob is free to swing back and
    forth in the plane of the page, to the left and right of a vertical line through
    the pendulum\u2019s pivot point."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
