  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Heat is caused by kinetic energy from the object, which we will call body
    or system. Heat is a form of energy because it is energy in spontaneous transfer
    caused by changes in temperature. Atoms vibrate at a certain frequency. If they
    receive energy, they\r\n \r\nvibrate faster, hence allowing the body to expand
    and release their own heat. If that heat is transferred from the body to another,
    losing that energy forces the atoms to vibrate less to conserve, allowing them
    to compact together.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
