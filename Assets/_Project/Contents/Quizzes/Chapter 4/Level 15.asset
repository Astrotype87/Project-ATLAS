      data:
        difficulty: 0
        question:
        - This refers to applying a force over a certain distance. Which of the following
          best describes this?
        - This refers to exerting a force across a specific distance. Which of the
          following best describes this?
        - This refers to applying force within a particular distance. Which of the
          following best describes this?
        correctAnswer:
        - Work
        wrongAnswers:
        - Power
        - Weight
        - Potential Energy
        choiceCount: 4
