  level: Level 1
  name: Units & Measurements
  description: Fundamental physical quantities like length, mass, and time are key
    to describing properties.
  quizItems:
  - rid: 7832858350227292163
  - rid: 7832858350227292164
  - rid: 7832858350227292165
