      data:
        difficulty: 0
        question:
        - Which of the following processes of heat transfer occurs when boiling water
          circulates inside a pot?
        - Which of the following describes the way soup in a pot circulates heat?
        - Which of the following heat transfer processes is demonstrated by boiling
          water?
        correctAnswer:
        - Convection
        wrongAnswers:
        - Radiation
        - Conduction
        - Reflection
        choiceCount: 4
    - rid: 138986247837974651
      type: {class: MultipleChoiceItem, ns: ProjectATLAS.Quiz, asm: Assembly-CSharp}
      data:
        difficulty: 0
        question:
        - Which of the following units is commonly used along with Joule to measure
          heat?
        - Which of the following is used to measure heat in food labels?
        - Which of the following is a unit of heat aside from Joule?
        correctAnswer:
        - Calorie
        wrongAnswers:
