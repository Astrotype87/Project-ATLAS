          unit: m/s
          range:
            min: 7
            max: 5
        - variable: V_BC
          name: Velocity of C relative to B
          unit: m/s
          range:
            min: 3
            max: 5
        variable: V_AC
        name: Velocity relative to the ground
        unit: m/s
        rounding: 2
