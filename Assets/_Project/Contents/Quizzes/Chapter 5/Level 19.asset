    - rid: 138986247837974664
      type: {class: SolvingItem, ns: ProjectATLAS.Quiz, asm: Assembly-CSharp}
      data:
        difficulty: 2
        question:
        - A toy car of {m1} kg is at {x1} meter, and a block of {m2} kg is at {x2}
