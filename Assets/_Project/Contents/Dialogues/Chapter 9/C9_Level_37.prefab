  m_Name: 
  m_EditorClassIdentifier: 
  steps:
  - message: There! Alien fuel crystals glowing near vents!
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Careful\u2014strong currents add extra force. Use thrust wisely."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "I\u2019ll balance buoyancy and fight the currents."
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: Excellent, {player}. Gather those crystals before we run out of oxygen!
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
