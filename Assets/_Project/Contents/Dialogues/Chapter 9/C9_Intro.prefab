--- !u!114 &149611779894335984
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6336052068413480240}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fbeb6d65be27d3b40a131a1e4ace56b5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  steps:
  - message: "{player}! I\u2019m glad you survived up to here! We\u2019re almost
      at the end of our journey!"
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "I couldn\u2019t have made it without you, Gizmo. Thanks for teaching
      and guiding me through all those challenges!"
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "You\u2019re always welcome, {player}. But... it seems our adventure
      isn\u2019t over yet."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Huh? What\u2019s going on this time?"
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "As you can see, we\u2019ve landed on a water world. But there\u2019s
      a problem\u2014the ship\u2019s fuel tank is empty."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Great\u2026 stranded in an endless ocean. OMG! What now?"
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Don\u2019t panic! There\u2019s hope. Alien fuel crystals are hidden
      deep underwater."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Underwater? So we\u2019ll have to dive for them?"
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: Yes! But before we dive, we need to test your knowledge on fluids haha!
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: Fluids? You mean like water and air?
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Precisely. Anything that flows\u2014liquids, gases, all obey the same
      fluid principles."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Sounds tricky, but I\u2019m ready. Let\u2019s do this, Gizmo!"
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "That\u2019s the spirit! Let\u2019s see how well you understand fluid
      behavior before we make the dive."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
