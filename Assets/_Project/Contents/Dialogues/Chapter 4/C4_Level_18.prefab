  m_Script: {fileID: 11500000, guid: fbeb6d65be27d3b40a131a1e4ace56b5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  steps:
  - message: "Final test\u2014start the airship\u2019s energy core."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: Sequence the glowing cores, right?
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: Yes. Correct order restores stability, wrong order overloads.
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Okay Gizmo, I\u2019ll light them one by one."
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Careful\u2026 steady\u2026 engines are waking up!"
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
