--- !u!114 &7931302465808967917
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2893876462498393675}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fbeb6d65be27d3b40a131a1e4ace56b5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  steps:
  - message: We have completely repaired our ship! We can finally take off, Gizmo!
      I'm so excited back to Earth!
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 0
    endTime: 0.99
    dialogueCondition: {fileID: 0}
  - message: Indeed {player}, let's get back to the ship and take off!
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0.99
    dialogueCondition: {fileID: 0}
  - message: We have successfully exit the volcano planet. Prepare yourself {player},
      we will use our hyperdrive to travel lightspeed back to Earth!
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 1
    endTime: 1.99
    dialogueCondition: {fileID: 0}
  - message: Woah! I didn't expect that sudden jump! Look at those stars, they are
      all bent in blue lines!
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 2
    endTime: 2.99
    dialogueCondition: {fileID: 0}
  - message: We have finally reached the Earth {player}, we are so close to our home!
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 3
    endTime: 3.99
    dialogueCondition: {fileID: 0}
  - message: We have landed at the docking station of the Sky Fortress {player}!
      Pack your item and lets meet our people.
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 4
    endTime: 4.99
    dialogueCondition: {fileID: 0}
  - message: Greetings Sir Chief! We have completed our space missions and arrived
      safe!
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 5
    endTime: 5.99
    dialogueCondition: {fileID: 0}
  - message: Congratulations {player} and Gizmo for completing all your space missions!
      You will be given a badge of ATLAS.
    character: {fileID: 11400000, guid: 7669520dceea11149b27394b7ddc466f, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 5
    endTime: 5.99
    dialogueCondition: {fileID: 0}
  - message: And the journery ends here...
    character: {fileID: 11400000, guid: a239437dcf872e6409de765deb4715f6, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 5
    endTime: 5.99
    dialogueCondition: {fileID: 0}
