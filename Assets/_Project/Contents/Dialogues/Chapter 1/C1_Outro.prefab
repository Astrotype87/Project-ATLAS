--- !u!114 &3565468141906147812
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 9073611175433636603}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fbeb6d65be27d3b40a131a1e4ace56b5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  steps:
  - message: "It\u2019s hovering! I actually did it!"
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 0
    endTime: 2
    dialogueCondition: {fileID: 0}
  - message: "Not just did it\u2014you understood it, {player}. Fundamentals fuel
      invention."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "What\u2019s next, Gizmo?"
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Beyond this hangar lies open desert \u2014 real tests of stability,
      terrain, and thrust."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Sounds like the perfect field to prove what I\u2019ve learned."
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Then onward, pilot. Your next challenge awaits \u2014 with science
      as your co-pilot!"
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 1
    startTime: 2
    endTime: 4
    dialogueCondition: {fileID: 0}
