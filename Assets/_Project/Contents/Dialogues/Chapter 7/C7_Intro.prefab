--- !u!114 &7326353176963355717
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8793001644957792652}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fbeb6d65be27d3b40a131a1e4ace56b5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  steps:
  - message: "The spacecraft module is ready, {player}. But before launch\u2014let\u2019s
      review gravity."
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Gravity\u2026 the invisible tether holding us down. Ready for the quiz."
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: What gives Earth its gravitational pull?
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: "Its mass\u2014more mass means stronger gravity."
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: Correct! And what happens when distance increases?
    character: {fileID: 11400000, guid: 6a96359884e70134880e3323cd90c5eb, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
  - message: Gravity weakens as distance grows.
    character: {fileID: 11400000, guid: a80ac0751277f424ca977c804190eff8, type: 2}
    dontUseTTS: 0
    useAnimation: 0
    startTime: 0
    endTime: 0
    dialogueCondition: {fileID: 0}
