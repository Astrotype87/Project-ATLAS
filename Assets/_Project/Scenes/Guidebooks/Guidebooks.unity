  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The term momentum is widely used in sports, as it means that things are
    on the move, and is going to take some amounts of effort to stop it. If a team
    has momentum, then it will be really hard to stop them from winning. \n\nMomentum
    is the amount of motion that an object has. Meaning, if an object is moving,
    it has momentum as well, kind of like moving inertia. is used in sports  a sports
    team that is on the move (meaning, gaining the advantage) has momentum!\n\n\rMomentum
    is also referred as mass in motion. If an object has mass, then it has momentum.
    Formula: p = m*v where m = mass and v = velocity\n\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
