  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A mechanical wave is a wave that results from interaction with matter.
    An example would be a child driving a rope tied to a post to form waves. In this
    example, the child is delivering force onto the rope, which creates a wave carrying
    the force. This force has a certain amount of energy traveling from the boy\u2019s
    hand up to the tree. Thus, the wave dies if it hits the tree, and if the child
    has had enough of creating waves. This wave has a limited transmission of matter."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_fontSharedMaterials: []
