  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Relative motion is a movement that is observed from another point of view.
    This motion requires three (3) reference frames the static reference (always
    referred to as A), the intermediate reference (referred to as B), and the moving
    reference (referred to as C). Since there is a common ground for both velocities,
    the formula is simply a linear vector equation, though it may change to suit
    the scenario.\nFormula: V_AC\xB2 = V_AB\xB2 + V_BC\xB2\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_fontSharedMaterials: []
