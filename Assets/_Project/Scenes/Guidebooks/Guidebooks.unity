  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "While some objects undergoing simple harmonic motion move back and forth
    as governed by Hooke\u2019s law, some objects rotate back and forth between two
    angular positions. These objects are generally called pendulums, whereas the
    objects that undergo Hooke\u2019s Law are called springs. Take, for example,
    a simple pendulum that moves back and forth at a certain angle, \u03B8. In its
    motion lie two equal angles, which can be shown by bisecting the angle itself. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
