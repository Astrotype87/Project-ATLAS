  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Two-Dimensional Components\t\r\nSteps in splitting a vector into its components:\r\n    
    1. Sketch the vector on the Cartesian coordinate system based on the given information.\r\n    
    2. Based on the quadrant where it is located, determine the sign of each component.\r\n    
    3. Determine which trigonometric function will give the  \t\r\nx- and y-components.\r\n    
    4. Multiply the magnitude of the vector to the appropriate trigonometric function
    of the angle to obtain the magnitude of the component.\r\n     5. Affix the sign
    of the components as obtained in step 2.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
