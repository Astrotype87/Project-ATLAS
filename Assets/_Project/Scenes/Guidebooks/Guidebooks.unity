  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The two-dimensional motion is projected within Cartesian plane with x
    and y, we shall be dealing with motion when projected along two dimensions: x
    and y. As seen in the image, there is a third arrow alongside the x and y axes.
    That arrow is called the resultant. It represents the motion in both dimensions.
    Simply put, it simplifies the direction taken by the object throughout its movement.
    \n\nFormula: V_R\xB2 = V_x\xB2 + V_y\xB2\nV_R\xB2 = resultant velocity\nV_x\xB2
    = x velocity\nV_y\xB2 = y velocity"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
