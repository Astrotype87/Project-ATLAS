  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Speed (represented as v) is the change in distance (d) per unit time (t).
    \nFormula: Speed: v = | d / t |\n\nVelocity (v\u0305) also has the same diagram
    as speed, but with some minor differences. Displacement (x) replaces the distance,
    and velocity replaces speed. \nFormula: Velocity: v\u02C9 = x / t\n\nAcceleration
    (a) also has the same diagram as both speed and velocity, but with some minor
    differences. Velocity (v\u0305) becomes the dependent variable. Acceleration\u2019s
    formula is seen in its given definition.\nFormula: Acceleration: a = v\u02C9\u200B
    / t"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
