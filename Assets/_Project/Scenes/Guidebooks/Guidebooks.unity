  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Newton\u2019s Law of Universal Gravitation stated that the farther the
    two (2) objects are from one another, the weaker the gravity. It is such gravity
    that astronauts experience once they are in outer space. They are within Earth\u2019s
    influence, yet at the same time, somehow experience some degree of freedom. This
    is called microgravity, in which the gravitational influence is so weak that
    the one experiencing it has that sensation of weightlessness."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
