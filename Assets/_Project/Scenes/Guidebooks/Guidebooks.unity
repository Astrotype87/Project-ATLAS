  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "We all know that gravity (Lat. gravis, \u201Cheavy\u201D) is a force that
    pulls everything towards its center. We are already experiencing its influence,
    from the glass of milk spilling to the floor to our aching feet due to standing
    for too long or diving from a cliff into the deep blue sea. We also know that
    the phrase, \u201CWhat comes up, must go down,\u201D somehow is influenced by
    it. We also know that gravity is a force, just like a push or pull. \n\nBut,
    gravity is more of a pull than a push. Actually, eliminate the push out of your
    mind whenever we talk about gravity because it will never push things away. That
    is the true nature of gravity.\n\nAn object has gravity because it has mass.
    The heavier an object is, the higher its gravity, even if two (2) objects have
    the same size. That is because one object has more stuff (i.e., mass) than the
    other. The other has less stuff; therefore, it has a lower influence than the
    other. \n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
