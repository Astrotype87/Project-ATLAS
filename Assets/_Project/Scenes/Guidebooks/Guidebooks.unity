  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Suppose we have a 65-kg man wearing an advanced prototype of a 3D Maneuver
    Gear (3DMG). He aimed his left and right reels at the peaks of two abandoned
    stone towers 375 meters above the ground, with the man standing at a building
    about 50 meters above the ground. The towers were 250 m away from the building.
    As the gear pulled him towards the two (2) towers at a rate of 56 m/s vertically,
    which changes after 4 seconds, as seen in the figure. What is the man\u2019s
    vertical height as soon as he hit the 4-second mark?\n\nThis setup is an example
    of Projectile Motion."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
  m_sharedMaterial: {fileID: -4890204404628985631, guid: ed9fe41215e4a2c4a9fa581443855244, type: 2}
